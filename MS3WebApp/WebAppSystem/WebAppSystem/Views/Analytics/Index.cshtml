@{
    ViewData["Title"] = "Analytics Dashboard";
}

<div class="mb-4">
    <h1><i class="bi bi-graph-up"></i> Analytics Dashboard</h1>
    <p class="lead">HR Analytics and Reporting</p>
    <hr />
</div>

<div class="row g-4">
    <!-- Department Statistics Card -->
    <div class="col-md-6">
        <div class="card shadow-sm h-100 border-primary">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="bi bi-building text-primary"></i> Department Statistics
                </h5>
                <p class="card-text">
                    View detailed employee statistics organized by department.
                </p>
                <ul class="list-unstyled">
                    <li><i class="bi bi-check-circle text-success"></i> Employee count per department</li>
                    <li><i class="bi bi-check-circle text-success"></i> Active vs inactive employees</li>
                    <li><i class="bi bi-check-circle text-success"></i> Department heads information</li>
                </ul>
                <a asp-action="DepartmentStatistics" class="btn btn-primary">
                    <i class="bi bi-arrow-right"></i> View Statistics
                </a>
            </div>
        </div>
    </div>

    <!-- Compliance Report Card -->
    <div class="col-md-6">
        <div class="card shadow-sm h-100 border-warning">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="bi bi-shield-check text-warning"></i> Compliance Reports
                </h5>
                <p class="card-text">
                    Search and generate compliance reports to ensure regulatory adherence.
                </p>
                <ul class="list-unstyled">
                    <li><i class="bi bi-check-circle text-success"></i> Contract compliance tracking</li>
                    <li><i class="bi bi-check-circle text-success"></i> Tax form verification</li>
                    <li><i class="bi bi-check-circle text-success"></i> Profile completion status</li>
                </ul>
                <a asp-action="ComplianceReport" class="btn btn-warning">
                    <i class="bi bi-arrow-right"></i> View Reports
                </a>
            </div>
        </div>
    </div>

    <!-- Diversity Report Card -->
    <div class="col-md-6">
        <div class="card shadow-sm h-100 border-info">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="bi bi-globe text-info"></i> Diversity Reports
                </h5>
                <p class="card-text">
                    Analyze workforce diversity across various dimensions.
                </p>
                <ul class="list-unstyled">
                    <li><i class="bi bi-check-circle text-success"></i> Geographic diversity</li>
                    <li><i class="bi bi-check-circle text-success"></i> Department distribution</li>
                    <li><i class="bi bi-check-circle text-success"></i> Employment status breakdown</li>
                </ul>
                <a asp-action="DiversityReport" class="btn btn-info">
                    <i class="bi bi-arrow-right"></i> View Reports
                </a>
            </div>
        </div>
    </div>

    <!-- Quick Insights Card -->
    <div class="col-md-6">
        <div class="card shadow-sm h-100 border-success">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="bi bi-lightbulb text-success"></i> Quick Insights
                </h5>
                <p class="card-text">
                    Key metrics and insights at a glance.
                </p>
                <div class="mt-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span><i class="bi bi-people"></i> Total Employees:</span>
                        <strong>@(ViewBag.TotalEmployees ?? 0)</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span><i class="bi bi-building"></i> Departments:</span>
                        <strong>@(ViewBag.TotalDepartments ?? 0)</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span><i class="bi bi-check-circle"></i> Active:</span>
                        <strong>@(ViewBag.ActiveEmployees ?? 0)</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
