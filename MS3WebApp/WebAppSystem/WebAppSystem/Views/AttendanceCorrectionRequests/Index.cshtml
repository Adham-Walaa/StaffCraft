@model IEnumerable<WebAppSystem.Models.AttendanceCorrectionRequest>

@{
    ViewData["Title"] = "Correction Requests";
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1><i class="bi bi-pen"></i> Attendance Correction Requests</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Create New
        </a>
    </div>
    <hr />
</div>

<div class="table-responsive">
    <table class="table table-hover table-striped">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Date)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.CorrectionType)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Reason)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Employee)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.RecommendedByNavigation)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Date)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.CorrectionType)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Reason)
            </td>
            <td>
                @{
                    var statusClass = item.Status?.ToLower() switch
                    {
                        "pending" => "badge bg-warning text-dark",
                        "approved" => "badge bg-success",
                        "rejected" => "badge bg-danger",
                        _ => "badge bg-secondary"
                    };
                }
                <span class="@statusClass">@(item.Status ?? "Unknown")</span>
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Employee.EmployeeId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.RecommendedByNavigation.EmployeeId)
            </td>
            <td>
                <div class="btn-group btn-group-sm" role="group">
                    <a asp-action="Details" asp-route-id="@item.RequestId" class="btn btn-info" title="Details">
                        <i class="bi bi-eye"></i>
                    </a>
                    @if (Context.Session.GetString("UserRoles")?.Contains("Line Manager") == true || 
                         Context.Session.GetString("UserRoles")?.Contains("HR Administrator") == true)
                    {
                        @if (item.Status != null && item.Status.Equals("Pending", StringComparison.OrdinalIgnoreCase))
                        {
                            <a asp-action="Approve" asp-route-id="@item.RequestId" class="btn btn-success" title="Approve">
                                <i class="bi bi-check-circle"></i>
                            </a>
                            <a asp-action="Reject" asp-route-id="@item.RequestId" class="btn btn-danger" title="Reject">
                                <i class="bi bi-x-circle"></i>
                            </a>
                        }
                    }
                </div>
            </td>
        </tr>
}
    </tbody>
</table>
