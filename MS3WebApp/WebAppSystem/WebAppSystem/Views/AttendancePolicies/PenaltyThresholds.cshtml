@model IEnumerable<WebAppSystem.Models.AttendancePolicy>

@{
    ViewData["Title"] = "Penalty Thresholds";
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1><i class="bi bi-calendar-x"></i> Penalty Thresholds</h1>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Policies
        </a>
    </div>
    <hr />
</div>

<div class="alert alert-danger">
    <i class="bi bi-info-circle"></i>
    <strong>Penalty Thresholds:</strong> Escalation rules that define when and how penalties increase based on the severity or frequency of attendance violations.
</div>

<div class="table-responsive">
    <table class="table table-hover table-striped">
        <thead class="table-danger">
            <tr>
                <th>Policy ID</th>
                <th>Threshold Name</th>
                <th>Description</th>
                <th>Configuration</th>
                <th>Effective Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.PolicyID</td>
                        <td><strong>@item.PolicyName</strong></td>
                        <td>@item.Description</td>
                        <td>
                            <code>@item.Parameters</code>
                        </td>
                        <td>@item.EffectiveDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            @if (item.Status == "Active")
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle"></i> Active
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    <i class="bi bi-x-circle"></i> @item.Status
                                </span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.PolicyID" class="btn btn-sm btn-info" title="View Details">
                                <i class="bi bi-eye"></i> Details
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center">
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i> No penalty thresholds configured. Please configure thresholds using the database procedures.
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model != null && Model.Any())
{
    <div class="card mt-4">
        <div class="card-header bg-danger text-white">
            <h5><i class="bi bi-lightbulb"></i> Understanding Penalty Thresholds</h5>
        </div>
        <div class="card-body">
            <h6>Threshold Escalation:</h6>
            <ul>
                <li><strong>Minor Violation:</strong> Late by 1-15 minutes → Warning or minimal deduction</li>
                <li><strong>Moderate Violation:</strong> Late by 16-30 minutes → Time deduction or partial day off</li>
                <li><strong>Major Violation:</strong> Late by 31+ minutes → Half-day or full-day deduction</li>
            </ul>
            <h6 class="mt-3">Threshold Types:</h6>
            <ul>
                <li><strong>Time-based:</strong> Penalties increase based on minutes late or early departure</li>
                <li><strong>Frequency-based:</strong> Repeated violations within a period trigger escalated penalties</li>
                <li><strong>Combined:</strong> Both time and frequency factors determine the penalty level</li>
            </ul>
            <h6 class="mt-3">Examples:</h6>
            <div class="table-responsive mt-2">
                <table class="table table-sm table-bordered">
                    <thead>
                        <tr>
                            <th>Minutes Late</th>
                            <th>Threshold Level</th>
                            <th>Typical Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>0-15 min</td>
                            <td class="text-success">Grace Period</td>
                            <td>No action (within grace)</td>
                        </tr>
                        <tr>
                            <td>16-30 min</td>
                            <td class="text-warning">Level 1</td>
                            <td>Warning + Time deduction</td>
                        </tr>
                        <tr>
                            <td>31-60 min</td>
                            <td class="text-danger">Level 2</td>
                            <td>Half-day deduction</td>
                        </tr>
                        <tr>
                            <td>60+ min</td>
                            <td class="text-danger">Level 3</td>
                            <td>Full-day absence</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <p class="mt-3">
                <strong>Note:</strong> Actual thresholds may vary based on organizational policies. Contact HR Administrator to review or modify these settings.
            </p>
        </div>
    </div>
}
