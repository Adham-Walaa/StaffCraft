@model WebAppSystem.Models.Attendance

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Attendance</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="AttendanceId" />
            <div class="form-group">
                <label asp-for="EmployeeId" class="control-label"></label>
                <select asp-for="EmployeeId" class="form-control" asp-items="ViewBag.EmployeeId"></select>
                <span asp-validation-for="EmployeeId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="EntryTime" class="control-label"></label>
                <input asp-for="EntryTime" type="text" class="form-control" placeholder="HH:MM (24-hour format, e.g., 09:00 or 23:00)" pattern="([01]?[0-9]|2[0-3]):[0-5][0-9]" />
                <span asp-validation-for="EntryTime" class="text-danger"></span>
                <small class="form-text text-muted">Enter time in 24-hour format (e.g., 09:00, 14:30, 23:45)</small>
            </div>
            <div class="form-group">
                <label asp-for="ExitTime" class="control-label"></label>
                <input asp-for="ExitTime" type="text" class="form-control" placeholder="HH:MM (24-hour format, e.g., 17:00)" pattern="([01]?[0-9]|2[0-3]):[0-5][0-9]" />
                <span asp-validation-for="ExitTime" class="text-danger"></span>
                <small class="form-text text-muted">Enter time in 24-hour format (e.g., 09:00, 14:30, 23:45)</small>
            </div>
            <div class="form-group">
                <label asp-for="Duration" class="control-label"></label>
                <input asp-for="Duration" type="number" class="form-control" readonly />
                <span asp-validation-for="Duration" class="text-danger"></span>
                <small class="form-text text-muted">Duration in minutes (auto-calculated)</small>
            </div>
            <div class="form-group">
                <label asp-for="LoginMethod" class="control-label"></label>
                <select asp-for="LoginMethod" class="form-control">
                    <option value="">-- Select Method --</option>
                    <option value="Web Portal">Web Portal</option>
                    <option value="Mobile App">Mobile App</option>
                    <option value="Biometric">Biometric</option>
                    <option value="Manual">Manual</option>
                </select>
                <span asp-validation-for="LoginMethod" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="LogoutMethod" class="control-label"></label>
                <select asp-for="LogoutMethod" class="form-control">
                    <option value="">-- Select Method --</option>
                    <option value="Web Portal">Web Portal</option>
                    <option value="Mobile App">Mobile App</option>
                    <option value="Biometric">Biometric</option>
                    <option value="Manual">Manual</option>
                </select>
                <span asp-validation-for="LogoutMethod" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ExceptionId" class="control-label"></label>
                <select asp-for="ExceptionId" class="form-control" asp-items="ViewBag.ExceptionId"></select>
                <span asp-validation-for="ExceptionId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
