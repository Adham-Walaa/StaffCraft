@model IEnumerable<WebAppSystem.Models.Attendance>

@{
    ViewData["Title"] = "All Attendance Records";
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1><i class="bi bi-clock-history"></i> All Attendance Records</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Create New
        </a>
    </div>
    <hr />
</div>

<div class="table-responsive">
    <table class="table table-hover table-striped">
    <thead>
        <tr>
            <th>
                Date
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Employee)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EntryTime)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ExitTime)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Duration)
            </th>
            <th>
                Status
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LoginMethod)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LogoutMethod)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @DateTime.Today.ToString("yyyy-MM-dd")
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Employee.EmployeeId)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EntryTime)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ExitTime)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Duration)
            </td>
            <td>
                @(item.EntryTime.HasValue && item.ExitTime.HasValue ? "Complete" : item.EntryTime.HasValue ? "In Progress" : "Absent")
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LoginMethod)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LogoutMethod)
            </td>
            <td>
                <div class="btn-group btn-group-sm" role="group">
                    <a asp-action="Details" asp-route-id="@item.AttendanceId" class="btn btn-info" title="Details">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a asp-action="Edit" asp-route-id="@item.AttendanceId" class="btn btn-warning" title="Edit">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a asp-action="Delete" asp-route-id="@item.AttendanceId" class="btn btn-danger" title="Delete">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </td>
        </tr>
}
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center" role="alert">
        <i class="bi bi-info-circle"></i> No attendance records found. <a asp-action="Create" class="alert-link">Create the first record</a>
    </div>
}
