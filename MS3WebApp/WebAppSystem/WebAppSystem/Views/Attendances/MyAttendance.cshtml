@model IEnumerable<WebAppSystem.Models.Attendance>

@{
    ViewData["Title"] = "My Attendance";
}

<h1>My Attendance</h1>

<p>
    <a asp-action="RecordAttendance" class="btn btn-primary">Record Attendance</a>
    <a asp-action="SyncOfflineAttendance" class="btn btn-secondary">Sync Offline Records</a>
    <a asp-controller="AttendanceCorrectionRequests" asp-action="SubmitRequest" class="btn btn-info">Submit Correction Request</a>
</p>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Date</th>
            <th>Entry Time</th>
            <th>Exit Time</th>
            <th>Duration (minutes)</th>
            <th>Login Method</th>
            <th>Logout Method</th>
            <th>Exception</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @DateTime.Now.ToString("yyyy-MM-dd")
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EntryTime)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ExitTime)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Duration)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LoginMethod)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.LogoutMethod)
            </td>
            <td>
                @(item.Exception?.Name ?? "None")
            </td>
            <td>
                <a asp-action="Details" asp-route-id="@item.AttendanceId" class="btn btn-sm btn-info">Details</a>
            </td>
        </tr>
}
    </tbody>
</table>
