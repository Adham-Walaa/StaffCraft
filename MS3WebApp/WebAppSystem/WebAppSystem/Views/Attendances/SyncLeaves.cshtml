@{
    ViewData["Title"] = "Sync Leaves with Attendance";
}

<h1>Sync Approved Leaves with Attendance System</h1>

<hr />

<div class="row">
    <div class="col-md-6">
        <div class="alert alert-info">
            <strong>About this feature:</strong><br />
            This will sync all approved leave requests with the attendance system. 
            Employees who are on approved leave will have attendance records created with a "Leave" exception.
        </div>

        <form asp-action="SyncLeaves" method="post">
            <div class="form-group mb-3">
                <label for="startDate" class="control-label">Start Date</label>
                <input type="date" id="startDate" name="startDate" class="form-control" required />
            </div>

            <div class="form-group mb-3">
                <label for="endDate" class="control-label">End Date</label>
                <input type="date" id="endDate" name="endDate" class="form-control" required />
            </div>

            <div class="form-group">
                <input type="submit" value="Sync Leaves" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Set default dates (last 30 days)
        var endDate = new Date();
        var startDate = new Date();
        startDate.setDate(endDate.getDate() - 30);
        
        document.getElementById('startDate').value = startDate.toISOString().split('T')[0];
        document.getElementById('endDate').value = endDate.toISOString().split('T')[0];
    </script>
}
