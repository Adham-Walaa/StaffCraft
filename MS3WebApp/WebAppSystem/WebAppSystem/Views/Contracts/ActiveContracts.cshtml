@model IEnumerable<WebAppSystem.Models.Contract>

@{
    ViewData["Title"] = "Active Contracts";
}

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h2 class="mb-0"><i class="bi bi-file-check"></i> Active Contracts</h2>
                <p class="mb-0">HR Administrator - View all active employment contracts</p>
            </div>
            <div class="card-body">
                @if (Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Contract ID</th>
                                    <th>Employee</th>
                                    <th>Type</th>
                                    <th>Start Date</th>
                                    <th>End Date</th>
                                    <th>Days Remaining</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var contract in Model)
                                {
                                    var daysRemaining = contract.EndDate.HasValue 
                                        ? (contract.EndDate.Value - DateTime.Now).Days 
                                        : 0;
                                    
                                    <tr>
                                        <td>@contract.ContractId</td>
                                        <td>
                                            @if (contract.Employees.Any())
                                            {
                                                @contract.Employees.First().FullName
                                            }
                                            else
                                            {
                                                <span class="text-muted">No employee assigned</span>
                                            }
                                        </td>
                                        <td>@contract.Type</td>
                                        <td>@(contract.StartDate?.ToString("yyyy-MM-dd") ?? "N/A")</td>
                                        <td>@(contract.EndDate?.ToString("yyyy-MM-dd") ?? "N/A")</td>
                                        <td>
                                            @if (daysRemaining > 60)
                                            {
                                                <span class="badge bg-success">@daysRemaining days</span>
                                            }
                                            else if (daysRemaining > 30)
                                            {
                                                <span class="badge bg-warning text-dark">@daysRemaining days</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">@daysRemaining days</span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge bg-success">@contract.CurrentState</span>
                                        </td>
                                        <td>
                                            <a asp-action="Details" asp-route-id="@contract.ContractId" class="btn btn-sm btn-info text-white">
                                                <i class="bi bi-eye"></i> View
                                            </a>
                                            <a asp-action="RenewContract" asp-route-id="@contract.ContractId" class="btn btn-sm btn-warning">
                                                <i class="bi bi-arrow-repeat"></i> Renew
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-3">
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> Total Active Contracts: <strong>@Model.Count()</strong>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i> No active contracts found.
                    </div>
                }

                <div class="mt-4">
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Create New Contract
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to All Contracts
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
