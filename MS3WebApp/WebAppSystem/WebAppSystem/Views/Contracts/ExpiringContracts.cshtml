@model IEnumerable<WebAppSystem.Controllers.ExpiringContractViewModel>

@{
    ViewData["Title"] = "Expiring Contracts";
}

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card shadow">
            <div class="card-header bg-danger text-white">
                <h2 class="mb-0"><i class="bi bi-exclamation-triangle"></i> Expiring Contracts</h2>
                <p class="mb-0">HR Administrator - Contracts expiring within @ViewBag.DaysBefore days</p>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <form asp-action="ExpiringContracts" method="get" class="row g-3">
                        <div class="col-auto">
                            <label for="daysBefore" class="form-label">Days Before Expiry:</label>
                        </div>
                        <div class="col-auto">
                            <select id="daysBefore" name="daysBefore" class="form-select">
                                <option value="7" @(ViewBag.DaysBefore == 7 ? "selected" : "")>7 days</option>
                                <option value="14" @(ViewBag.DaysBefore == 14 ? "selected" : "")>14 days</option>
                                <option value="30" @(ViewBag.DaysBefore == 30 ? "selected" : "")>30 days</option>
                                <option value="60" @(ViewBag.DaysBefore == 60 ? "selected" : "")>60 days</option>
                                <option value="90" @(ViewBag.DaysBefore == 90 ? "selected" : "")>90 days</option>
                            </select>
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-search"></i> Filter
                            </button>
                        </div>
                    </form>
                </div>

                <hr />

                @if (Model.Any())
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle-fill"></i> <strong>Urgent Action Required!</strong> 
                        Found <strong>@Model.Count()</strong> contract(s) expiring within the next @ViewBag.DaysBefore days.
                    </div>

                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Contract ID</th>
                                    <th>Employee ID</th>
                                    <th>Employee Name</th>
                                    <th>Email</th>
                                    <th>Type</th>
                                    <th>Start Date</th>
                                    <th>End Date</th>
                                    <th>Days Until Expiry</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var contract in Model.OrderBy(c => c.DaysUntilExpiry))
                                {
                                    <tr class="@(contract.DaysUntilExpiry <= 7 ? "table-danger" : contract.DaysUntilExpiry <= 30 ? "table-warning" : "")">
                                        <td>@contract.ContractID</td>
                                        <td>@contract.EmployeeID</td>
                                        <td><strong>@contract.EmployeeName</strong></td>
                                        <td>@contract.Email</td>
                                        <td>@contract.ContractType</td>
                                        <td>@contract.StartDate.ToString("yyyy-MM-dd")</td>
                                        <td>@contract.EndDate.ToString("yyyy-MM-dd")</td>
                                        <td>
                                            @if (contract.DaysUntilExpiry <= 7)
                                            {
                                                <span class="badge bg-danger">@contract.DaysUntilExpiry days - URGENT</span>
                                            }
                                            else if (contract.DaysUntilExpiry <= 30)
                                            {
                                                <span class="badge bg-warning text-dark">@contract.DaysUntilExpiry days</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info">@contract.DaysUntilExpiry days</span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-action="Details" asp-route-id="@contract.ContractID" class="btn btn-sm btn-info text-white">
                                                <i class="bi bi-eye"></i> View
                                            </a>
                                            <a asp-action="RenewContract" asp-route-id="@contract.ContractID" class="btn btn-sm btn-success text-white">
                                                <i class="bi bi-arrow-repeat"></i> Renew Now
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-3">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h5 class="card-title">Summary</h5>
                                <ul class="list-unstyled mb-0">
                                    <li><i class="bi bi-circle-fill text-danger"></i> Expiring within 7 days: <strong>@Model.Count(c => c.DaysUntilExpiry <= 7)</strong></li>
                                    <li><i class="bi bi-circle-fill text-warning"></i> Expiring within 8-30 days: <strong>@Model.Count(c => c.DaysUntilExpiry > 7 && c.DaysUntilExpiry <= 30)</strong></li>
                                    <li><i class="bi bi-circle-fill text-info"></i> Expiring beyond 30 days: <strong>@Model.Count(c => c.DaysUntilExpiry > 30)</strong></li>
                                </ul>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle"></i> No contracts expiring within the next @ViewBag.DaysBefore days.
                    </div>
                }

                <div class="mt-4">
                    <a asp-action="ActiveContracts" class="btn btn-success">
                        <i class="bi bi-file-check"></i> View Active Contracts
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to All Contracts
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
