@model IEnumerable<WebAppSystem.Models.Contract>

@{
    ViewData["Title"] = "Expiring Contracts";
}

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card shadow">
            <div class="card-header bg-warning text-dark">
                <h2 class="mb-0"><i class="bi bi-clock-history"></i> Expiring Contracts</h2>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <form method="get" asp-action="ExpiringContracts" class="row g-3">
                        <div class="col-auto">
                            <label for="daysBefore" class="col-form-label">Show contracts expiring within:</label>
                        </div>
                        <div class="col-auto">
                            <select name="daysBefore" id="daysBefore" class="form-select">
                                <option value="7" selected="@(ViewBag.DaysBefore == 7)">7 days</option>
                                <option value="14" selected="@(ViewBag.DaysBefore == 14)">14 days</option>
                                <option value="30" selected="@(ViewBag.DaysBefore == 30)">30 days</option>
                                <option value="60" selected="@(ViewBag.DaysBefore == 60)">60 days</option>
                                <option value="90" selected="@(ViewBag.DaysBefore == 90)">90 days</option>
                            </select>
                        </div>
                        <div class="col-auto">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-search"></i> Filter
                            </button>
                        </div>
                    </form>
                </div>

                <hr />

                @if (Model.Any())
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle-fill"></i> <strong>Urgent Action Required!</strong> 
                        Found <strong>@Model.Count()</strong> contract(s) expiring within the next @ViewBag.DaysBefore days.
                    </div>

                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Contract ID</th>
                                    <th>Employee</th>
                                    <th>Type</th>
                                    <th>Start Date</th>
                                    <th>End Date</th>
                                    <th>Days Until Expiry</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var contract in Model.OrderBy(c => c.EndDate))
                                {
                                    var daysUntilExpiry = contract.EndDate.HasValue ? (contract.EndDate.Value.Date - DateTime.Today).Days : 0;
                                    var rowClass = daysUntilExpiry <= 7 ? "table-danger" : daysUntilExpiry <= 30 ? "table-warning" : "";
                                    
                                    <tr class="@rowClass">
                                        <td>@contract.ContractId</td>
                                        <td>
                                            @if (contract.Employees != null && contract.Employees.Any())
                                            {
                                                foreach (var employee in contract.Employees)
                                                {
                                                    <div><strong>@employee.FullName</strong></div>
                                                    <small class="text-muted">@employee.Email</small>
                                                }
                                            }
                                            else
                                            {
                                                <span class="text-muted">No employee assigned</span>
                                            }
                                        </td>
                                        <td>@contract.Type</td>
                                        <td>@(contract.StartDate?.ToString("MMM dd, yyyy") ?? "N/A")</td>
                                        <td>
                                            <span class="badge bg-@(daysUntilExpiry <= 7 ? "danger" : daysUntilExpiry <= 30 ? "warning text-dark" : "info")">
                                                @(contract.EndDate?.ToString("MMM dd, yyyy") ?? "N/A")
                                            </span>
                                        </td>
                                        <td>
                                            <strong>@daysUntilExpiry days</strong>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a asp-action="Details" asp-route-id="@contract.ContractId" 
                                                   class="btn btn-info" title="Details">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <a asp-action="RenewContract" asp-route-id="@contract.ContractId" 
                                                   class="btn btn-success" title="Renew Contract">
                                                    <i class="bi bi-arrow-repeat"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle-fill"></i> <strong>Great News!</strong> 
                        No contracts are expiring within the next @ViewBag.DaysBefore days.
                    </div>
                }

                <div class="mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to Contracts List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
