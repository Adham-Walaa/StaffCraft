@{
    ViewData["Title"] = "Assign Team Member";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h2 class="mb-0"><i class="bi bi-person-plus"></i> Assign Team Member</h2>
            </div>
            <div class="card-body">
                <p class="text-muted">
                    As a Line Manager, you can assign employees to your team or to other managers' teams.
                </p>

                <form asp-action="AssignTeamMember" method="post" class="mt-4">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label for="employeeId" class="form-label">Select Employee</label>
                        <select id="employeeId" name="employeeId" class="form-select" required>
                            <option value="">-- Select an Employee --</option>
                            @foreach (var item in (SelectList)ViewData["EmployeeId"])
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                        <div class="form-text">
                            Select an employee to assign to a team. Employees marked as "Already assigned" can be reassigned to a different manager.
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="managerId" class="form-label">Assign to Manager</label>
                        <select id="managerId" name="managerId" class="form-select" required>
                            @foreach (var item in (SelectList)ViewData["ManagerId"])
                            {
                                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                            }
                        </select>
                        <div class="form-text">
                            Select the manager to whom this employee should report.
                        </div>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a asp-action="MyTeam" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> Assign Employee
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
