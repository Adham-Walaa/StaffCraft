@model WebAppSystem.Models.Employee

@{
    ViewData["Title"] = "Change Employee Password";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header bg-warning text-dark">
                <h2 class="mb-0"><i class="bi bi-key"></i> Change Employee Password</h2>
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <h5 class="text-primary">Employee Information</h5>
                    <dl class="row">
                        <dt class="col-sm-3">Employee ID:</dt>
                        <dd class="col-sm-9">@Model.EmployeeId</dd>

                        <dt class="col-sm-3">Full Name:</dt>
                        <dd class="col-sm-9">@Model.FullName</dd>

                        <dt class="col-sm-3">Email:</dt>
                        <dd class="col-sm-9">@Model.Email</dd>
                    </dl>
                </div>

                <hr class="my-4" />

                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle"></i> <strong>Warning:</strong> You are about to change the password for this employee. Make sure to communicate the new password to the employee securely.
                </div>

                <form asp-action="ChangePassword" method="post" class="mt-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.EmployeeId" />

                    <div class="mb-3">
                        <label for="newPassword" class="form-label">New Password</label>
                        <input type="password" class="form-control" id="newPassword" name="newPassword" required minlength="6" />
                        <div class="form-text">Password must be at least 6 characters long.</div>
                    </div>

                    <div class="mb-3">
                        <label for="confirmPassword" class="form-label">Confirm Password</label>
                        <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required minlength="6" />
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a asp-action="Details" asp-route-id="@Model.EmployeeId" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-warning" onclick="return confirm('Are you sure you want to change this employee\'s password?');">
                            <i class="bi bi-key"></i> Change Password
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
