@model WebAppSystem.Models.Employee

@{
    ViewData["Title"] = "Employee Details";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-10">
        <div class="card shadow">
            <div class="card-header bg-info text-white">
                <h2 class="mb-0"><i class="bi bi-person-badge"></i> Employee Details</h2>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Employee ID</dt>
                    <dd class="col-sm-9">@Model.EmployeeId</dd>

                    <dt class="col-sm-3">First Name</dt>
                    <dd class="col-sm-9">@Model.FirstName</dd>

                    <dt class="col-sm-3">Last Name</dt>
                    <dd class="col-sm-9">@Model.LastName</dd>

                    <dt class="col-sm-3">Full Name</dt>
                    <dd class="col-sm-9">@Model.FullName</dd>

                    <dt class="col-sm-3">National ID</dt>
                    <dd class="col-sm-9">@Model.NationalId</dd>

                    <dt class="col-sm-3">Date of Birth</dt>
                    <dd class="col-sm-9">@(Model.DateOfBirth?.ToString("MMM dd, yyyy") ?? "N/A")</dd>

                    <dt class="col-sm-3">Country of Birth</dt>
                    <dd class="col-sm-9">@Model.CountryOfBirth</dd>

                    <dt class="col-sm-3">Phone</dt>
                    <dd class="col-sm-9">@Model.Phone</dd>

                    <dt class="col-sm-3">Email</dt>
                    <dd class="col-sm-9">@Model.Email</dd>

                    <dt class="col-sm-3">Address</dt>
                    <dd class="col-sm-9">@Model.Address</dd>

                    <dt class="col-sm-3">Emergency Contact Name</dt>
                    <dd class="col-sm-9">@Model.EmergencyContactName</dd>

                    <dt class="col-sm-3">Emergency Contact Phone</dt>
                    <dd class="col-sm-9">@Model.EmergencyContactPhone</dd>

                    <dt class="col-sm-3">Relationship</dt>
                    <dd class="col-sm-9">@Model.Relationship</dd>

                    <dt class="col-sm-3">Biography</dt>
                    <dd class="col-sm-9">@Model.Biography</dd>

                    <dt class="col-sm-3">Employment Progress</dt>
                    <dd class="col-sm-9">@Model.EmploymentProgress</dd>

                    <dt class="col-sm-3">Account Status</dt>
                    <dd class="col-sm-9">@Model.AccountStatus</dd>

                    <dt class="col-sm-3">Employment Status</dt>
                    <dd class="col-sm-9">@Model.EmploymentStatus</dd>

                    <dt class="col-sm-3">Hire Date</dt>
                    <dd class="col-sm-9">@(Model.HireDate?.ToString("MMM dd, yyyy") ?? "N/A")</dd>

                    <dt class="col-sm-3">Is Active</dt>
                    <dd class="col-sm-9">
                        @if (Model.IsActive == true)
                        {
                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Active</span>
                        }
                        else
                        {
                            <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Inactive</span>
                        }
                    </dd>

                    <dt class="col-sm-3">Profile Completion</dt>
                    <dd class="col-sm-9">
                        <div class="progress" style="width: 200px;">
                            <div class="progress-bar" role="progressbar" style="width: @(Model.ProfileCompletionPercentage ?? 0)%">
                                @(Model.ProfileCompletionPercentage ?? 0)%
                            </div>
                        </div>
                    </dd>

                    @if (Model.Department != null)
                    {
                        <dt class="col-sm-3">Department</dt>
                        <dd class="col-sm-9">@Model.Department.DepartmentName</dd>
                    }

                    @if (Model.Position != null)
                    {
                        <dt class="col-sm-3">Position</dt>
                        <dd class="col-sm-9">@Model.Position.PositionTitle</dd>
                    }

                    @if (Model.Manager != null)
                    {
                        <dt class="col-sm-3">Manager</dt>
                        <dd class="col-sm-9">@Model.Manager.FullName</dd>
                    }

                    @if (Model.Paygrade != null)
                    {
                        <dt class="col-sm-3">Pay Grade</dt>
                        <dd class="col-sm-9">@Model.Paygrade.GradeName</dd>
                    }

                    @if (Model.SalaryType != null)
                    {
                        <dt class="col-sm-3">Salary Type</dt>
                        <dd class="col-sm-9">@Model.SalaryType.Type</dd>
                    }

                    @if (Model.Taxform != null)
                    {
                        <dt class="col-sm-3">Tax Form</dt>
                        <dd class="col-sm-9">@Model.Taxform.Jurisdiction</dd>
                    }
                </dl>

                <hr class="my-4" />

                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    @if (Context.Session.GetString("UserRoles")?.Contains("HR Administrator") == true)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.EmployeeId" class="btn btn-warning">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                    }
                    @if (Context.Session.GetString("UserRoles")?.Contains("System Administrator") == true)
                    {
                        <a asp-action="ManageRoles" asp-route-id="@Model.EmployeeId" class="btn btn-primary">
                            <i class="bi bi-shield-check"></i> Manage Roles
                        </a>
                    }
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
