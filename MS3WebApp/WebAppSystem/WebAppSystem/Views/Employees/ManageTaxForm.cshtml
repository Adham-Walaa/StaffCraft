@model WebAppSystem.Models.Employee

@{
    ViewData["Title"] = "Manage Tax Form";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-10">
        <div class="card shadow">
            <div class="card-header bg-danger text-white">
                <h2 class="mb-0"><i class="bi bi-file-earmark-text"></i> Manage Tax Form</h2>
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <h5 class="text-primary">Employee Information</h5>
                    <dl class="row">
                        <dt class="col-sm-3">Employee ID:</dt>
                        <dd class="col-sm-9">@Model.EmployeeId</dd>

                        <dt class="col-sm-3">Full Name:</dt>
                        <dd class="col-sm-9">@Model.FullName</dd>

                        <dt class="col-sm-3">Email:</dt>
                        <dd class="col-sm-9">@Model.Email</dd>

                        <dt class="col-sm-3">Department:</dt>
                        <dd class="col-sm-9">@(Model.Department?.DepartmentName ?? "N/A")</dd>

                        <dt class="col-sm-3">Position:</dt>
                        <dd class="col-sm-9">@(Model.Position?.PositionTitle ?? "N/A")</dd>
                    </dl>
                </div>

                <hr class="my-4" />

                <div class="mb-4">
                    <h5 class="text-primary">Current Tax Form</h5>
                    @if (ViewBag.CurrentTaxForm != null)
                    {
                        <div class="alert alert-info">
                            <strong>@ViewBag.CurrentTaxForm.Jurisdiction</strong><br />
                            <small>
                                Validity Period: @(ViewBag.CurrentTaxForm.ValidityPeriod?.ToString("MMM dd, yyyy") ?? "N/A")
                            </small>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i> No tax form assigned yet.
                        </div>
                    }
                </div>

                <hr class="my-4" />

                <div>
                    <h5 class="text-primary">Assign Tax Form</h5>
                    <form asp-action="AssignTaxForm" method="post" class="row g-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="employeeId" value="@Model.EmployeeId" />

                        <div class="col-md-8">
                            <label for="taxFormId" class="form-label">Select Tax Form</label>
                            <select id="taxFormId" name="taxFormId" class="form-select">
                                <option value="">-- Remove Tax Form --</option>
                                @foreach (var item in (SelectList)ViewBag.AvailableTaxForms)
                                {
                                    <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-4 d-flex align-items-end">
                            <button type="submit" class="btn btn-danger w-100">
                                <i class="bi bi-check-circle"></i> Update Tax Form
                            </button>
                        </div>
                    </form>

                    <div class="mt-3">
                        <a asp-controller="TaxForms" asp-action="Create" 
                           asp-route-returnToEmployeeId="@Model.EmployeeId" 
                           asp-route-returnToAction="ManageTaxForm" 
                           class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-plus-circle"></i> Create New Tax Form
                        </a>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    <a asp-action="Details" asp-route-id="@Model.EmployeeId" class="btn btn-outline-primary">
                        <i class="bi bi-eye"></i> View Full Profile
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to Employee List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
