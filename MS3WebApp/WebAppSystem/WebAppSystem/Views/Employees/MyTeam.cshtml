@model IEnumerable<WebAppSystem.Models.Employee>

@{
    ViewData["Title"] = "My Team";
}

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h2 class="mb-0"><i class="bi bi-people"></i> My Team</h2>
                <p class="mb-0">Manager: @ViewBag.ManagerName</p>
            </div>
            <div class="card-body">
                @* Show manager section if employee has a manager *@
                @if (ViewBag.MyManager != null)
                {
                    <div class="mb-4">
                        <h4 class="mb-3"><i class="bi bi-person-badge"></i> My Manager</h4>
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-primary">
                                    <tr>
                                        <th>Employee ID</th>
                                        <th>Full Name</th>
                                        <th>Email</th>
                                        <th>Phone</th>
                                        <th>Department</th>
                                        <th>Position</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>@ViewBag.MyManager.EmployeeId</td>
                                        <td>@ViewBag.MyManager.FullName</td>
                                        <td>@ViewBag.MyManager.Email</td>
                                        <td>@ViewBag.MyManager.Phone</td>
                                        <td>@(ViewBag.MyManager.Department?.DepartmentName ?? "N/A")</td>
                                        <td>@(ViewBag.MyManager.Position?.PositionTitle ?? "N/A")</td>
                                        <td>
                                            <a asp-action="Details" asp-route-id="@ViewBag.MyManager.EmployeeId" class="btn btn-info btn-sm text-white" title="View Details">
                                                <i class="bi bi-eye"></i> View
                                            </a>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                }

                @* Show team members section *@
                @if (Model.Any())
                {
                    <h4 class="mb-3"><i class="bi bi-people-fill"></i> My Direct Reports</h4>
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Employee ID</th>
                                    <th>Full Name</th>
                                    <th>Email</th>
                                    <th>Phone</th>
                                    <th>Department</th>
                                    <th>Position</th>
                                    <th>Hire Date</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var employee in Model)
                                {
                                    <tr>
                                        <td>@employee.EmployeeId</td>
                                        <td>@employee.FullName</td>
                                        <td>@employee.Email</td>
                                        <td>@employee.Phone</td>
                                        <td>@(employee.Department?.DepartmentName ?? "N/A")</td>
                                        <td>@(employee.Position?.PositionTitle ?? "N/A")</td>
                                        <td>@(employee.HireDate?.ToString("yyyy-MM-dd") ?? "N/A")</td>
                                        <td>
                                            @if (employee.EmploymentStatus == "Active")
                                            {
                                                <span class="badge bg-success">@employee.EmploymentStatus</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@employee.EmploymentStatus</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a asp-action="Details" asp-route-id="@employee.EmployeeId" class="btn btn-info text-white" title="View Details">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <form asp-action="RemoveTeamMember" method="post" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="employeeId" value="@employee.EmployeeId" />
                                                    <input type="hidden" name="employeeName" value="@employee.FullName" />
                                                    <button type="submit" class="btn btn-danger btn-sm" title="Remove from Team"
                                                            onclick="return confirm('Are you sure you want to remove this employee from your team?');">
                                                        <i class="bi bi-person-dash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-3">
                        <div class="alert alert-info">
                            <i class="bi bi-info-circle"></i> Total Team Members: <strong>@Model.Count()</strong>
                        </div>
                    </div>
                }
                else if (ViewBag.MyManager == null)
                {
                    @* Show message only if employee has no team AND no manager *@
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i> No team members assigned to you yet. 
                        @if (ViewBag.IsLineManager)
                        {
                            <text>Use the button below to assign employees to your team.</text>
                        }
                        else
                        {
                            <text>Contact a Line Manager if you need team members assigned to you.</text>
                        }
                    </div>
                }
                else
                {
                    @* Employee has a manager but no direct reports *@
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> You do not have any direct reports at this time.
                        @if (ViewBag.IsLineManager)
                        {
                            <text>Use the button below to assign employees to your team.</text>
                        }
                    </div>
                }

                <div class="mt-4">
                    @if (ViewBag.IsLineManager)
                    {
                        <a asp-action="AssignTeamMember" class="btn btn-success me-2">
                            <i class="bi bi-person-plus"></i> Assign Team Member
                        </a>
                    }
                    <a asp-action="Index" asp-controller="Home" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
