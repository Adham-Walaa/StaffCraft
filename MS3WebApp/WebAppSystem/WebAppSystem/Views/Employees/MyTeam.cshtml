@model IEnumerable<WebAppSystem.Models.TeamMemberViewModel>

@{
    ViewData["Title"] = "My Team";
}

<div class="row mt-4">
    <div class="col-md-12">
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h2 class="mb-0"><i class="bi bi-people"></i> My Team (Hierarchical View)</h2>
                <p class="mb-0">Manager: @ViewBag.ManagerName</p>
            </div>
            <div class="card-body">
                @if (Model.Any())
                {
                    <div class="alert alert-info mb-3">
                        <i class="bi bi-info-circle"></i> This view shows all employees in your team hierarchy, including indirect reports (employees who report to your direct reports).
                    </div>

                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead class="table-dark">
                                <tr>
                                    <th>Level</th>
                                    <th>Employee ID</th>
                                    <th>Full Name</th>
                                    <th>Reports To</th>
                                    <th>Email</th>
                                    <th>Phone</th>
                                    <th>Department</th>
                                    <th>Position</th>
                                    <th>Hire Date</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var employee in Model)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge bg-primary">L@employee.HierarchyLevel</span>
                                        </td>
                                        <td>@employee.EmployeeId</td>
                                        <td>
                                            @if (employee.HierarchyLevel > 1)
                                            {
                                                <span style="margin-left: @((employee.HierarchyLevel - 1) * 15)px;">
                                                    <i class="bi bi-arrow-return-right text-muted"></i>
                                                </span>
                                            }
                                            <strong>@employee.FullName</strong>
                                            @if (employee.HierarchyLevel > 1)
                                            {
                                                <span class="badge bg-secondary ms-1" title="Indirect Report">Indirect</span>
                                            }
                                        </td>
                                        <td>
                                            @if (employee.Manager != null)
                                            {
                                                <span>@employee.Manager.FullName</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">You</span>
                                            }
                                        </td>
                                        <td>@employee.Email</td>
                                        <td>@employee.Phone</td>
                                        <td>@(employee.Department?.DepartmentName ?? "N/A")</td>
                                        <td>@(employee.Position?.PositionTitle ?? "N/A")</td>
                                        <td>@(employee.HireDate?.ToString("yyyy-MM-dd") ?? "N/A")</td>
                                        <td>
                                            @if (employee.EmploymentStatus == "Active")
                                            {
                                                <span class="badge bg-success">@employee.EmploymentStatus</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@employee.EmploymentStatus</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a asp-action="Details" asp-route-id="@employee.EmployeeId" class="btn btn-info text-white" title="View Full Details">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                @if (employee.HierarchyLevel == 1)
                                                {
                                                    <form asp-action="RemoveTeamMember" method="post" style="display:inline;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="employeeId" value="@employee.EmployeeId" />
                                                        <input type="hidden" name="employeeName" value="@employee.FullName" />
                                                        <button type="submit" class="btn btn-danger btn-sm" title="Remove from Team"
                                                                onclick="return confirm('Are you sure you want to remove @employee.FullName from your direct team? This will also affect their subordinates.');">
                                                            <i class="bi bi-person-dash"></i>
                                                        </button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <button class="btn btn-secondary btn-sm" disabled title="Cannot remove indirect reports. Remove their direct manager instead.">
                                                        <i class="bi bi-person-dash"></i>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-3 row">
                        <div class="col-md-6">
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle"></i> <strong>Total Team Members:</strong> @Model.Count()
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="alert alert-success">
                                <i class="bi bi-people"></i> <strong>Direct Reports:</strong> @Model.Count(m => m.HierarchyLevel == 1)
                            </div>
                        </div>
                    </div>

                    @if (Model.Any(m => m.HierarchyLevel > 1))
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle"></i> <strong>Note:</strong> You can only directly manage (remove) your Level 1 (direct) reports. To manage indirect reports, you need to work through their immediate supervisor.
                        </div>
                    }
                }
                else
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i> No team members found. You may not have any direct reports assigned yet. Use the "Assign Team Member" button below to build your team.
                    </div>
                }

                <div class="mt-4">
                    <a asp-action="AssignTeamMember" class="btn btn-success me-2">
                        <i class="bi bi-person-plus"></i> Assign Team Member
                    </a>
                    <a asp-action="Index" asp-controller="Home" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
