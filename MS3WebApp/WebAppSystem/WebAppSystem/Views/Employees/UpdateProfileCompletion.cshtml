@model WebAppSystem.Models.Employee

@{
    ViewData["Title"] = "Update Profile Completion";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h2 class="mb-0"><i class="bi bi-percent"></i> Manage Profile Completion</h2>
                <p class="mb-0 small">HR Administrator - Manage employee profile completeness</p>
            </div>
            <div class="card-body">
                <div class="mb-4">
                    <h5 class="text-primary">Employee Information</h5>
                    <dl class="row">
                        <dt class="col-sm-4">Employee ID:</dt>
                        <dd class="col-sm-8">@Model.EmployeeId</dd>

                        <dt class="col-sm-4">Full Name:</dt>
                        <dd class="col-sm-8">@Model.FullName</dd>

                        <dt class="col-sm-4">Email:</dt>
                        <dd class="col-sm-8">@Model.Email</dd>

                        <dt class="col-sm-4">Department:</dt>
                        <dd class="col-sm-8">@(Model.Department?.DepartmentName ?? "N/A")</dd>

                        <dt class="col-sm-4">Position:</dt>
                        <dd class="col-sm-8">@(Model.Position?.PositionTitle ?? "N/A")</dd>

                        <dt class="col-sm-4">Current Profile Completion:</dt>
                        <dd class="col-sm-8">
                            <div class="progress">
                                <div class="progress-bar @(Model.ProfileCompletionPercentage >= 80 ? "bg-success" : Model.ProfileCompletionPercentage >= 50 ? "bg-warning" : "bg-danger")" 
                                     role="progressbar" 
                                     style="width: @(Model.ProfileCompletionPercentage ?? 0)%" 
                                     aria-valuenow="@(Model.ProfileCompletionPercentage ?? 0)" 
                                     aria-valuemin="0" 
                                     aria-valuemax="100">
                                    @(Model.ProfileCompletionPercentage ?? 0)%
                                </div>
                            </div>
                        </dd>
                    </dl>
                </div>

                <hr class="my-4" />

                <form asp-action="UpdateProfileCompletion" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" name="id" value="@Model.EmployeeId" />

                    <div class="form-group mb-3">
                        <label for="profileCompletionPercentage" class="form-label">
                            Profile Completion Percentage
                        </label>
                        <input type="range" 
                               class="form-range" 
                               id="profileCompletionPercentage" 
                               name="profileCompletionPercentage" 
                               min="0" 
                               max="100" 
                               step="5"
                               value="@(Model.ProfileCompletionPercentage ?? 0)"
                               oninput="document.getElementById('percentageValue').textContent = this.value + '%'" />
                        <div class="text-center mt-2">
                            <span class="badge bg-primary fs-5" id="percentageValue">@(Model.ProfileCompletionPercentage ?? 0)%</span>
                        </div>
                        <small class="form-text text-muted">
                            Adjust the slider to set the profile completion percentage (0-100%)
                        </small>
                    </div>

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> <strong>Profile Completion Guidelines:</strong>
                        <ul class="mb-0 mt-2">
                            <li>0-30%: Basic information only (Name, Email)</li>
                            <li>31-60%: Contact details and emergency contacts added</li>
                            <li>61-80%: Employment details, department, and position assigned</li>
                            <li>81-100%: All information complete including contract, biography, and documents</li>
                        </ul>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-check-circle"></i> Update Profile Completion
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.EmployeeId" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
