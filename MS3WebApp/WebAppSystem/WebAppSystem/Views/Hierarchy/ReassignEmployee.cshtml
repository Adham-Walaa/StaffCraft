@model WebAppSystem.Models.Employee

@{
    ViewData["Title"] = "Reassign Employee";
}

<div class="mb-4">
    <h1><i class="bi bi-arrow-left-right"></i> Reassign Employee</h1>
    <hr />
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Employee Information</h5>
                <dl class="row">
                    <dt class="col-sm-4">Employee ID:</dt>
                    <dd class="col-sm-8">@Model.EmployeeId</dd>
                    
                    <dt class="col-sm-4">Name:</dt>
                    <dd class="col-sm-8">@Model.FullName</dd>
                    
                    <dt class="col-sm-4">Current Department:</dt>
                    <dd class="col-sm-8">@(Model.Department?.DepartmentName ?? "N/A")</dd>
                    
                    <dt class="col-sm-4">Current Manager:</dt>
                    <dd class="col-sm-8">@(Model.Manager?.FullName ?? "N/A")</dd>
                    
                    <dt class="col-sm-4">Position:</dt>
                    <dd class="col-sm-8">@(Model.Position?.PositionId.ToString() ?? "N/A")</dd>
                </dl>
                
                <hr />
                
                <form asp-action="ReassignEmployee" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.EmployeeId" />
                    
                    <div class="mb-3">
                        <label for="newDepartmentId" class="form-label">New Department</label>
                        <select class="form-select" id="newDepartmentId" name="newDepartmentId">
                            <option value="">-- Keep Current Department --</option>
                            @foreach (var dept in ViewData["Departments"] as SelectList)
                            {
                                <option value="@dept.Value">@dept.Text</option>
                            }
                        </select>
                        <div class="form-text">Select a new department for this employee, or leave blank to keep current.</div>
                    </div>

                    <div class="mb-3">
                        <label for="newManagerId" class="form-label">New Manager</label>
                        <select class="form-select" id="newManagerId" name="newManagerId">
                            <option value="">-- Keep Current Manager --</option>
                            @foreach (var mgr in ViewData["Managers"] as SelectList)
                            {
                                <option value="@mgr.Value">@mgr.Text</option>
                            }
                        </select>
                        <div class="form-text">Select a new manager for this employee, or leave blank to keep current.</div>
                    </div>

                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i>
                        <strong>Note:</strong> You must select at least one field to update (Department or Manager).
                    </div>

                    <div class="d-flex justify-content-between">
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-arrow-left-right"></i> Reassign Employee
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card bg-light">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-info-circle"></i> Reassignment Info</h5>
                <p class="card-text">
                    This action will reassign the employee to a new department and/or manager in the organizational hierarchy.
                </p>
                <hr />
                <h6>Important Notes:</h6>
                <ul>
                    <li>The change will be reflected immediately in the hierarchy</li>
                    <li>If assigning both, the new manager must be in the new department</li>
                    <li>The employee cannot be their own manager</li>
                    <li>All current team members will remain unchanged unless reassigned separately</li>
                </ul>
            </div>
        </div>
    </div>
</div>
