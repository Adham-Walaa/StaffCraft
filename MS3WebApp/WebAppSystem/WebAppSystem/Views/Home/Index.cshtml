@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-5">
    @if (Context.Session.GetInt32("UserId") != null)
    {
        <div class="text-center mb-5">
            <h1 class="display-4">Welcome, @Context.Session.GetString("UserName")!</h1>
            <p class="lead">Today's date is @DateTime.Now.ToString("MMMM dd, yyyy")</p>
        </div>

        <div class="row g-4">
            <!-- Employee Management Card -->
            <div class="col-md-6 col-xl-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="bi bi-people text-primary"></i> Employee Management
                        </h5>
                        @if (Context.Session.GetString("UserRoles")?.Contains("HR Administrator") == true || 
                             Context.Session.GetString("UserRoles")?.Contains("System Administrator") == true)
                        {
                            <p class="card-text">View all employees and update employee details.</p>
                        }
                        else
                        {
                            <p class="card-text">View all employees.</p>
                        }
                        <a asp-controller="Employees" asp-action="Index" class="btn btn-primary">
                            <i class="bi bi-arrow-right"></i> Go to Employees
                        </a>
                    </div>
                </div>
            </div>

            <!-- Contract Management Card -->
            <div class="col-md-6 col-xl-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="bi bi-file-earmark-text text-success"></i> Contract Management
                        </h5>
                        @if (Context.Session.GetString("UserRoles")?.Contains("HR Administrator") == true || 
                             Context.Session.GetString("UserRoles")?.Contains("System Administrator") == true)
                        {
                            <p class="card-text">View and renew contracts.</p>
                        }
                        else
                        {
                            <p class="card-text">View active contracts.</p>
                        }
                        <a asp-controller="Contracts" asp-action="Index" class="btn btn-success">
                            <i class="bi bi-arrow-right"></i> Go to Contracts
                        </a>
                    </div>
                </div>
            </div>

            <!-- My Team Card -->
            @if (Context.Session.GetString("UserRoles")?.Contains("Line Manager") == true)
            {
                <div class="col-md-6 col-xl-3">
                    <div class="card shadow-sm h-100 border-info">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="bi bi-people-fill text-info"></i> My Team
                            </h5>
                            <p class="card-text">View and manage your team.</p>
                            <a asp-controller="Employees" asp-action="MyTeam" class="btn btn-info text-white">
                                <i class="bi bi-arrow-right"></i> View My Team
                            </a>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="col-md-6 col-xl-3">
                    <div class="card shadow-sm h-100 @(ViewBag.HasDirectReports == true ? "border-warning" : "border-secondary")">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="bi bi-people-fill @(ViewBag.HasDirectReports == true ? "text-warning" : "text-secondary")"></i> My Team
                            </h5>
                            <p class="card-text">View your team.</p>
                            <a asp-controller="Employees" asp-action="MyTeam" class="btn @(ViewBag.HasDirectReports == true ? "btn-warning" : "btn-secondary")">
                                <i class="bi bi-arrow-right"></i> View My Team
                            </a>
                        </div>
                    </div>
                </div>
            }

            <!-- My Profile Card -->
            <div class="col-md-6 col-xl-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <i class="bi bi-person-circle text-secondary"></i> My Profile
                        </h5>
                        <p class="card-text">View and update your personal information.</p>
                        <a asp-controller="Employees" asp-action="MyProfile" class="btn btn-secondary">
                            <i class="bi bi-arrow-right"></i> View Profile
                        </a>
                    </div>
                </div>
            </div>

            @if (Context.Session.GetString("UserRoles")?.Contains("HR Administrator") == true)
            {
                <!-- HR Quick Actions Card -->
                <div class="col-md-6 col-xl-3">
                    <div class="card shadow-sm h-100 border-warning">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="bi bi-lightning text-warning"></i> HR Quick Actions
                            </h5>
                            <p class="card-text">Common HR administrative tasks.</p>
                            <div class="d-grid gap-2">
                                <a asp-controller="Contracts" asp-action="Create" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-plus-circle"></i> Create Contract
                                </a>
                                <a asp-controller="Contracts" asp-action="ExpiringContracts" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-exclamation-triangle"></i> Expiring Contracts
                                </a>
                                <a asp-controller="Contracts" asp-action="ActiveContracts" class="btn btn-sm btn-outline-success">
                                    <i class="bi bi-check-circle"></i> Active Contracts
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Employee Leave Request Card -->
                <div class="col-md-6 col-xl-3">
                    <div class="card shadow-sm h-100 border-info">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="bi bi-calendar-check text-info"></i> Employee Leave Requests
                            </h5>
                            <p class="card-text">Review and manage employee leave requests.</p>
                            <a asp-controller="LeaveRequests" asp-action="HRLeaveRequests" class="btn btn-info text-white">
                                <i class="bi bi-arrow-right"></i> View Leave Requests
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Leave Types Management Card -->
                <div class="col-md-6 col-xl-3">
                    <div class="card shadow-sm h-100 border-success">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="bi bi-gear-fill text-success"></i> Leave Types & Policies
                            </h5>
                            <p class="card-text">Configure leave types, policies, and eligibility rules.</p>
                            <a asp-controller="Leaves" asp-action="Index" class="btn btn-success text-white">
                                <i class="bi bi-arrow-right"></i> Manage Leave Types
                            </a>
                        </div>
                    </div>
                </div>
            }

            @if (Context.Session.GetString("UserRoles")?.Contains("Line Manager") == true)
            {
                <!-- Manager Leave Request Card -->
                <div class="col-md-6 col-xl-3">
                    <div class="card shadow-sm h-100 border-primary">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="bi bi-people-fill text-primary"></i> Team Leave Requests
                            </h5>
                            <p class="card-text">Review and manage leave requests from your team.</p>
                            <a asp-controller="LeaveRequests" asp-action="ManagerLeaveRequests" class="btn btn-primary">
                                <i class="bi bi-arrow-right"></i> View Team Requests
                            </a>
                        </div>
                    </div>
                </div>
            }

            @if (Context.Session.GetString("UserRoles")?.Contains("System Administrator") == true)
            {
                <!-- System Admin Card -->
                <div class="col-md-6 col-xl-3">
                    <div class="card shadow-sm h-100 border-danger">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="bi bi-shield-check text-danger"></i> System Administration
                            </h5>
                            <p class="card-text">Manage system roles and employee accounts.</p>
                            <div class="d-grid gap-2">
                                <a asp-controller="Account" asp-action="CreateEmployee" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-person-plus"></i> Create Employee Account
                                </a>
                                <a asp-controller="Employees" asp-action="Index" class="btn btn-sm btn-outline-info">
                                    <i class="bi bi-people"></i> View All Employees
                                </a>
                                <hr class="my-1" />
                                <a asp-controller="Employees" asp-action="SelectEmployeeForManagement" asp-route-managementType="Role" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-shield"></i> Manage Roles
                                </a>
                                <a asp-controller="Employees" asp-action="SelectEmployeeForManagement" asp-route-managementType="PayGrade" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-cash-stack"></i> Manage Pay Grades
                                </a>
                                <a asp-controller="Employees" asp-action="SelectEmployeeForManagement" asp-route-managementType="Position" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-briefcase"></i> Manage Positions
                                </a>
                                <a asp-controller="Employees" asp-action="SelectEmployeeForManagement" asp-route-managementType="SalaryType" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-currency-dollar"></i> Manage Salary Types
                                </a>
                                <a asp-controller="Employees" asp-action="SelectEmployeeForManagement" asp-route-managementType="TaxForm" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-file-earmark-text"></i> Manage Tax Forms
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center">
            <h1 class="display-4">Welcome to Team Entities' © Management System</h1>
            <hr class="my-4" />
            <p>Please login to access the system.</p>
            <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg">
                <i class="bi bi-box-arrow-in-right"></i> Login
            </a>
            <a asp-controller="Account" asp-action="Register" class="btn btn-outline-primary btn-lg">
                <i class="bi bi-person-plus"></i> Register
            </a>
        </div>
    }
</div>
