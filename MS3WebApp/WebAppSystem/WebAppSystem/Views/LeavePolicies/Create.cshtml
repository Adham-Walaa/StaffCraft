@model WebAppSystem.Models.LeavePolicy

@{
    ViewData["Title"] = "Create Leave Policy";
}

<div class="container mt-4">
    <h2>Create New Leave Policy</h2>
    <p class="text-muted">Configure a new leave policy with eligibility rules</p>

    <hr />
    
    <div class="row">
        <div class="col-md-8">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="mb-3">
                    <label asp-for="PolicyId" class="form-label"></label>
                    <input asp-for="PolicyId" class="form-control" />
                    <span asp-validation-for="PolicyId" class="text-danger"></span>
                    <small class="form-text text-muted">Unique identifier for this policy</small>
                </div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="e.g., Annual Leave Policy" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Purpose" class="form-label"></label>
                    <textarea asp-for="Purpose" class="form-control" rows="3" 
                              placeholder="e.g., Provides employees with paid time off for rest and personal matters"></textarea>
                    <span asp-validation-for="Purpose" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="EligibilityRules" class="form-label"></label>
                    <textarea asp-for="EligibilityRules" class="form-control" rows="4" 
                              placeholder="e.g., Available to full-time employees with 6+ months of service. Requires 2 weeks notice for requests exceeding 5 days."></textarea>
                    <span asp-validation-for="EligibilityRules" class="text-danger"></span>
                    <small class="form-text text-muted">
                        Define who is eligible and under what conditions. Examples:
                        <ul>
                            <li>Minimum tenure requirements (e.g., "6 months of service")</li>
                            <li>Employment type restrictions (e.g., "Full-time employees only")</li>
                            <li>Maximum days per occurrence or per year</li>
                            <li>Notice period requirements</li>
                        </ul>
                    </small>
                </div>

                <div class="mb-3">
                    <label asp-for="NoticePeriod" class="form-label"></label>
                    <input asp-for="NoticePeriod" type="datetime-local" class="form-control" />
                    <span asp-validation-for="NoticePeriod" class="text-danger"></span>
                    <small class="form-text text-muted">Optional: Minimum notice period required (stored as datetime)</small>
                </div>

                <div class="mb-3">
                    <label asp-for="SpecialLeaveType" class="form-label"></label>
                    <input asp-for="SpecialLeaveType" class="form-control" 
                           placeholder="e.g., Maternity, Paternity, Compassionate, Study Leave" />
                    <span asp-validation-for="SpecialLeaveType" class="text-danger"></span>
                    <small class="form-text text-muted">Leave this blank for standard policies</small>
                </div>

                <div class="mb-3 form-check">
                    <input type="checkbox" class="form-check-input" id="ResetOnNewYear" name="ResetOnNewYear" value="true" />
                    <label for="ResetOnNewYear" class="form-check-label">Reset On New Year</label>
                    <span asp-validation-for="ResetOnNewYear" class="text-danger"></span>
                    <br />
                    <small class="form-text text-muted">Check this if leave balances should reset annually on January 1st</small>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle"></i> Create Policy
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
