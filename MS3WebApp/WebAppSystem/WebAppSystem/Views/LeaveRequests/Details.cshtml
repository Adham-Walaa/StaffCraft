@model WebAppSystem.Models.LeaveRequest

@{
    ViewData["Title"] = "Details";
}

<h1>Leave Request Details</h1>

<div>
    <h4>LeaveRequest</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-3">
            Employee Name
        </dt>
        <dd class = "col-sm-9">
            @if (Model.Employee != null)
            {
                @Html.DisplayFor(model => model.Employee.FullName)
            }
            else
            {
                <span class="text-muted">N/A</span>
            }
        </dd>
        <dt class = "col-sm-3">
            Employee ID
        </dt>
        <dd class = "col-sm-9">
            @if (Model.Employee != null)
            {
                @Html.DisplayFor(model => model.Employee.EmployeeId)
            }
            else
            {
                <span class="text-muted">N/A</span>
            }
        </dd>
        <dt class = "col-sm-3">
            Leave Type
        </dt>
        <dd class = "col-sm-9">
            @if (Model.Leave != null)
            {
                @Html.DisplayFor(model => model.Leave.LeaveType)
            }
            else
            {
                <span class="text-muted">N/A</span>
            }
        </dd>
        <dt class = "col-sm-3">
            @Html.DisplayNameFor(model => model.Duration)
        </dt>
        <dd class = "col-sm-9">
            @Html.DisplayFor(model => model.Duration) days
        </dd>
        <dt class = "col-sm-3">
            @Html.DisplayNameFor(model => model.Justification)
        </dt>
        <dd class = "col-sm-9">
            @Html.DisplayFor(model => model.Justification)
        </dd>
        <dt class = "col-sm-3">
            Submitted Date
        </dt>
        <dd class = "col-sm-9">
            @if (Model.SubmissionDate.HasValue)
            {
                @Model.SubmissionDate.Value.ToString("MMMM dd, yyyy hh:mm tt")
            }
            else
            {
                <span class="text-muted">N/A</span>
            }
        </dd>
        <dt class = "col-sm-3">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class = "col-sm-9">
            @if (Model.Status == "Approved")
            {
                <span class="badge bg-success">
                    <i class="bi bi-check-circle"></i> Approved
                </span>
            }
            else if (Model.Status == "Rejected")
            {
                <span class="badge bg-danger">
                    <i class="bi bi-x-circle"></i> Rejected
                </span>
            }
            else
            {
                <span class="badge bg-warning text-dark">
                    <i class="bi bi-clock"></i> Pending
                </span>
            }
        </dd>
        <dt class = "col-sm-3">
            @if (Model.Status == "Approved")
            {
                <text>Approved Date</text>
            }
            else if (Model.Status == "Rejected")
            {
                <text>Rejected Date</text>
            }
            else
            {
                <text>Decision Date</text>
            }
        </dt>
        <dd class = "col-sm-9">
            @if (Model.ApprovalTiming.HasValue)
            {
                @Model.ApprovalTiming.Value.ToString("MMMM dd, yyyy hh:mm tt")
            }
            else
            {
                <span class="text-muted">Pending decision</span>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Index">Back to List</a>
</div>
