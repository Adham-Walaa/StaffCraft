@model IEnumerable<WebAppSystem.Models.LeaveRequest>

@{
    ViewData["Title"] = "Employee Leave Requests";
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1><i class="bi bi-calendar-check"></i> Employee Leave Requests</h1>
        <a asp-action="AdjustLeaveBalance" class="btn btn-outline-primary">
            <i class="bi bi-sliders"></i> Adjust Leave Balances
        </a>
    </div>
    <hr />
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No pending leave requests at this time.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Request ID</th>
                    <th>Employee</th>
                    <th>Leave Type</th>
                    <th>Duration (Days)</th>
                    <th>Justification</th>
                    <th>Attachments</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
@foreach (var item in Model) {
                <tr>
                    <td>@item.RequestId</td>
                    <td>
                        @if (item.Employee != null)
                        {
                            <strong>@item.Employee.FullName</strong><br />
                            <small class="text-muted">ID: @item.Employee.EmployeeId</small>
                        }
                        else
                        {
                            <span class="text-muted">N/A</span>
                        }
                    </td>
                    <td>
                        @if (item.Leave != null)
                        {
                            <span class="badge bg-primary">@item.Leave.LeaveType</span>
                        }
                        else
                        {
                            <span class="text-muted">N/A</span>
                        }
                    </td>
                    <td>@item.Duration</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.Justification))
                        {
                            if (item.Justification.Length > 50)
                            {
                                @item.Justification.Substring(0, 50)<text>...</text>
                            }
                            else
                            {
                                @item.Justification
                            }
                        }
                        else
                        {
                            <span class="text-muted">No justification provided</span>
                        }
                    </td>
                    <td>
                        @if (item.LeaveDocuments != null && item.LeaveDocuments.Any())
                        {
                            <span class="badge bg-success">
                                <i class="bi bi-paperclip"></i> @item.LeaveDocuments.Count
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">None</span>
                        }
                    </td>
                    <td>
                        <span class="badge bg-warning text-dark">
                            <i class="bi bi-clock"></i> @item.Status
                        </span>
                    </td>
                    <td>
                        <div class="btn-group btn-group-sm" role="group">
                            <a asp-action="Details" asp-route-id="@item.RequestId" class="btn btn-info" title="View Details">
                                <i class="bi bi-eye"></i>
                            </a>
                            <form asp-action="ApproveLeaveRequest" asp-route-id="@item.RequestId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success" title="Approve" onclick="return confirm('Are you sure you want to approve this leave request?');">
                                    <i class="bi bi-check-circle"></i>
                                </button>
                            </form>
                            <form asp-action="RejectLeaveRequest" asp-route-id="@item.RequestId" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-danger" title="Reject" onclick="return confirm('Are you sure you want to reject this leave request?');">
                                    <i class="bi bi-x-circle"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
}
            </tbody>
        </table>
    </div>
}

<div class="mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-house"></i> Back to Home
    </a>
</div>
