@model IEnumerable<WebAppSystem.Models.LeaveRequest>

@{
    ViewData["Title"] = "Team Leave Requests";
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="bi bi-people"></i> Team Leave Requests</h1>
            <p class="text-muted mb-0">Manage leave requests from your team members</p>
        </div>
    </div>
    <hr />
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-dark align-middle">
                    <thead>
                        <tr>
                            <th>Request ID</th>
                            <th>Employee</th>
                            <th>Leave Type</th>
                            <th>Duration (days)</th>
                            <th>Justification</th>
                            <th>Attachments</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.RequestId</td>
                                <td>
                                    <strong>@item.Employee.FullName</strong><br />
                                    <small class="text-muted">@item.Employee.Email</small>
                                </td>
                                <td>
                                    <span class="badge bg-primary">@item.Leave.LeaveType</span>
                                </td>
                                <td>
                                    <strong>@item.Duration</strong> days
                                </td>
                                <td>
                                    <div style="max-width: 250px; overflow: hidden; text-overflow: ellipsis;">
                                        @if (!string.IsNullOrEmpty(item.Justification))
                                        {
                                            @if (item.Justification.Contains("[FLAGGED BY MANAGER"))
                                            {
                                                <span class="badge bg-warning text-dark mb-1">
                                                    <i class="bi bi-flag-fill"></i> Flagged
                                                </span><br />
                                            }
                                            <span>@(item.Justification.Length > 100 ? item.Justification.Substring(0, 100) + "..." : item.Justification)</span>
                                        }
                                        else
                                        {
                                            <em class="text-muted">No justification provided</em>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @if (item.LeaveDocuments != null && item.LeaveDocuments.Any())
                                    {
                                        <span class="badge bg-info">
                                            <i class="bi bi-paperclip"></i> @item.LeaveDocuments.Count
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">None</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-clock"></i> Pending
                                        </span>
                                    }
                                    else if (item.Status == "Approved")
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle"></i> Approved
                                        </span>
                                    }
                                    else if (item.Status == "Rejected")
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-x-circle"></i> Rejected
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group" role="group">
                                        <form asp-action="ManagerApproveLeaveRequest" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@item.RequestId" />
                                            <button type="submit" class="btn btn-sm btn-success" title="Approve">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                        <form asp-action="ManagerRejectLeaveRequest" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@item.RequestId" />
                                            <button type="submit" class="btn btn-sm btn-danger" title="Reject">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </form>
                                        <button type="button" class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#flagModal@(item.RequestId)" title="Flag Irregular Pattern">
                                            <i class="bi bi-flag"></i>
                                        </button>
                                    </div>

                                    <!-- Flag Modal -->
                                    <div class="modal fade" id="flagModal@(item.RequestId)" tabindex="-1" aria-labelledby="flagModalLabel@(item.RequestId)" aria-hidden="true">
                                        <div class="modal-dialog">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title" id="flagModalLabel@(item.RequestId)">Flag Irregular Leave Pattern</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                </div>
                                                <form asp-action="FlagIrregularPattern" method="post">
                                                    <div class="modal-body">
                                                        <input type="hidden" name="id" value="@item.RequestId" />
                                                        <div class="mb-3">
                                                            <label for="patternNotes@(item.RequestId)" class="form-label">Pattern Notes</label>
                                                            <textarea class="form-control" id="patternNotes@(item.RequestId)" name="patternNotes" rows="3" placeholder="Describe the irregular pattern observed (e.g., frequent Monday absences, pattern around holidays)" required></textarea>
                                                            <div class="form-text">This note will be added to the leave request for HR review.</div>
                                                        </div>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                        <button type="submit" class="btn btn-warning">
                                                            <i class="bi bi-flag-fill"></i> Flag Request
                                                        </button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No pending leave requests from your team members.
    </div>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Back to All Leave Requests
    </a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
