@model IEnumerable<WebAppSystem.Models.Leave>

@{
    ViewData["Title"] = "Manage Leave Types";
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1><i class="bi bi-list-ul"></i> Manage Leave Types</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Create New Leave Type
        </a>
    </div>
    <hr />
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> No leave types have been configured yet.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Leave Type</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
@foreach (var item in Model) {
                <tr>
                    <td>
                        <span class="badge bg-primary">@Html.DisplayFor(modelItem => item.LeaveType)</span>
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.LeaveDescription)
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.LeaveId" class="btn btn-sm btn-warning" title="Edit">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <a asp-action="Details" asp-route-id="@item.LeaveId" class="btn btn-sm btn-info" title="View Details">
                            <i class="bi bi-eye"></i> Details
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.LeaveId" class="btn btn-sm btn-danger" title="Delete">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    </td>
                </tr>
}
            </tbody>
        </table>
    </div>
}

<div class="mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-house"></i> Back to Home
    </a>
</div>
