@model WebAppSystem.Models.Mission

@{
    ViewData["Title"] = "Delete Mission";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h2 class="mb-0"><i class="bi bi-trash"></i> Delete Mission</h2>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i> <strong>Warning!</strong> Are you sure you want to delete this mission? This action cannot be undone.
                    </div>

                    <dl class="row">
                        <dt class="col-sm-3">Mission ID</dt>
                        <dd class="col-sm-9">@Model.MissionId</dd>

                        <dt class="col-sm-3">Title</dt>
                        <dd class="col-sm-9"><strong>@Model.Title</strong></dd>

                        <dt class="col-sm-3">Description</dt>
                        <dd class="col-sm-9">@Model.Description</dd>

                        <dt class="col-sm-3">Destination</dt>
                        <dd class="col-sm-9">@Model.Destination</dd>

                        <dt class="col-sm-3">Start Date</dt>
                        <dd class="col-sm-9">@(Model.StartDate?.ToString("MMMM dd, yyyy") ?? "N/A")</dd>

                        <dt class="col-sm-3">End Date</dt>
                        <dd class="col-sm-9">@(Model.EndDate?.ToString("MMMM dd, yyyy") ?? "N/A")</dd>

                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9">@Model.Status</dd>

                        <dt class="col-sm-3">Assigned Employee</dt>
                        <dd class="col-sm-9">@(Model.Employee?.FullName ?? "Not assigned")</dd>

                        <dt class="col-sm-3">Manager</dt>
                        <dd class="col-sm-9">@(Model.Manager?.FullName ?? "N/A")</dd>
                    </dl>
                    
                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="MissionId" />
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Delete Mission
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
