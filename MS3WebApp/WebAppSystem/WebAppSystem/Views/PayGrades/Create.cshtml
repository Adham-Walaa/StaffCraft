@model WebAppSystem.Models.PayGrade

@{
    ViewData["Title"] = "Create Pay Grade";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h2 class="mb-0"><i class="bi bi-cash-stack"></i> Create Pay Grade</h2>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="mb-3">
                        <label asp-for="GradeName" class="form-label"></label>
                        <input asp-for="GradeName" class="form-control" placeholder="e.g., Grade A, Senior Level" />
                        <span asp-validation-for="GradeName" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="MinSalary" class="form-label"></label>
                        <input asp-for="MinSalary" class="form-control" type="number" step="0.01" placeholder="Minimum salary for this grade" />
                        <span asp-validation-for="MinSalary" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="MaxSalary" class="form-label"></label>
                        <input asp-for="MaxSalary" class="form-control" type="number" step="0.01" placeholder="Maximum salary for this grade" />
                        <span asp-validation-for="MaxSalary" class="text-danger"></span>
                    </div>
                    
                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle"></i> Create Pay Grade
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
