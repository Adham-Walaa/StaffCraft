@model IEnumerable<WebAppSystem.Models.PayGrade>

@{
    ViewData["Title"] = "Pay Grades";
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1><i class="bi bi-cash-stack"></i> Pay Grades</h1>
        @if (Context.Session.GetString("UserRoles")?.Contains("System Administrator") == true)
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Create New
            </a>
        }
    </div>
    <hr />
</div>

<div class="table-responsive">
    <table class="table table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>Pay Grade ID</th>
                <th>@Html.DisplayNameFor(model => model.GradeName)</th>
                <th>@Html.DisplayNameFor(model => model.MinSalary)</th>
                <th>@Html.DisplayNameFor(model => model.MaxSalary)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model) {
            <tr>
                <td>@item.PayGradeId</td>
                <td>@Html.DisplayFor(modelItem => item.GradeName)</td>
                <td>@(item.MinSalary?.ToString("C") ?? "N/A")</td>
                <td>@(item.MaxSalary?.ToString("C") ?? "N/A")</td>
                <td>
                    <div class="btn-group btn-group-sm" role="group">
                        <a asp-action="Details" asp-route-id="@item.PayGradeId" class="btn btn-info" title="Details">
                            <i class="bi bi-eye"></i>
                        </a>
                        @if (Context.Session.GetString("UserRoles")?.Contains("System Administrator") == true)
                        {
                            <a asp-action="Edit" asp-route-id="@item.PayGradeId" class="btn btn-warning" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.PayGradeId" class="btn btn-danger" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                        }
                    </div>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center" role="alert">
        <i class="bi bi-info-circle"></i> No pay grades found. 
        @if (Context.Session.GetString("UserRoles")?.Contains("System Administrator") == true)
        {
            <a asp-action="Create" class="alert-link">Create the first pay grade</a>
        }
    </div>
}
