@model WebAppSystem.Models.Position

@{
    ViewData["Title"] = "Create Position";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header bg-warning text-dark">
                <h2 class="mb-0"><i class="bi bi-briefcase"></i> Create Position</h2>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    
                    <div class="mb-3">
                        <label asp-for="PositionTitle" class="form-label"></label>
                        <input asp-for="PositionTitle" class="form-control" placeholder="e.g., Software Engineer, Product Manager" />
                        <span asp-validation-for="PositionTitle" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Responsibilities" class="form-label"></label>
                        <textarea asp-for="Responsibilities" class="form-control" rows="4" placeholder="Describe the key responsibilities of this position"></textarea>
                        <span asp-validation-for="Responsibilities" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Status" class="form-label"></label>
                        <select asp-for="Status" class="form-select">
                            <option value="">-- Select Status --</option>
                            <option value="Active">Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>
                    
                    <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-check-circle"></i> Create Position
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
