@model WebAppSystem.Models.Position

@{
    ViewData["Title"] = "Position Details";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-10">
        <div class="card shadow">
            <div class="card-header bg-warning text-dark">
                <h2 class="mb-0"><i class="bi bi-briefcase"></i> Position Details</h2>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Position ID</dt>
                    <dd class="col-sm-9">@Model.PositionId</dd>
                    
                    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.PositionTitle)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.PositionTitle)</dd>
                    
                    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Responsibilities)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.Responsibilities)</dd>
                    
                    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Status)</dt>
                    <dd class="col-sm-9">
                        @if (Model.Status == "Active")
                        {
                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Active</span>
                        }
                        else if (Model.Status == "Inactive")
                        {
                            <span class="badge bg-secondary"><i class="bi bi-x-circle"></i> Inactive</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@Model.Status</span>
                        }
                    </dd>
                </dl>
                
                <hr class="my-4" />
                
                <h5 class="mb-3"><i class="bi bi-people"></i> Employees with this Position</h5>
                @if (ViewBag.AssignedEmployees != null && ViewBag.AssignedEmployees.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Employee ID</th>
                                    <th>Name</th>
                                    <th>Email</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var employee in ViewBag.AssignedEmployees)
                                {
                                    <tr>
                                        <td>@employee.EmployeeId</td>
                                        <td>@employee.FullName</td>
                                        <td>@employee.Email</td>
                                        <td>
                                            <a asp-controller="Employees" asp-action="Details" asp-route-id="@employee.EmployeeId" 
                                               class="btn btn-sm btn-outline-info" title="View Employee">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <p class="text-muted"><small>Total: @ViewBag.AssignedEmployees.Count employee(s)</small></p>
                }
                else
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> No employees currently assigned to this position.
                    </div>
                }
                
                <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                    @if (Context.Session.GetString("UserRoles")?.Contains("System Administrator") == true)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.PositionId" class="btn btn-warning">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.PositionId" class="btn btn-danger">
                            <i class="bi bi-trash"></i> Delete
                        </a>
                    }
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
