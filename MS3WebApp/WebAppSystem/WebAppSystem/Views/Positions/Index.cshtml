@model IEnumerable<WebAppSystem.Models.Position>

@{
    ViewData["Title"] = "Positions";
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1><i class="bi bi-briefcase"></i> Positions</h1>
        @if (Context.Session.GetString("UserRoles")?.Contains("System Administrator") == true)
        {
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Create New
            </a>
        }
    </div>
    <hr />
</div>

<div class="table-responsive">
    <table class="table table-hover table-striped">
        <thead class="table-dark">
            <tr>
                <th>Position ID</th>
                <th>@Html.DisplayNameFor(model => model.PositionTitle)</th>
                <th>@Html.DisplayNameFor(model => model.Responsibilities)</th>
                <th>@Html.DisplayNameFor(model => model.Status)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model) {
            <tr>
                <td>@item.PositionId</td>
                <td>@Html.DisplayFor(modelItem => item.PositionTitle)</td>
                <td>@Html.DisplayFor(modelItem => item.Responsibilities)</td>
                <td>
                    @if (item.Status == "Active")
                    {
                        <span class="badge bg-success">
                            <i class="bi bi-check-circle"></i> Active
                        </span>
                    }
                    else if (item.Status == "Inactive")
                    {
                        <span class="badge bg-secondary">
                            <i class="bi bi-x-circle"></i> Inactive
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@item.Status</span>
                    }
                </td>
                <td>
                    <div class="btn-group btn-group-sm" role="group">
                        <a asp-action="Details" asp-route-id="@item.PositionId" class="btn btn-info" title="Details">
                            <i class="bi bi-eye"></i>
                        </a>
                        @if (Context.Session.GetString("UserRoles")?.Contains("System Administrator") == true)
                        {
                            <a asp-action="Edit" asp-route-id="@item.PositionId" class="btn btn-warning" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.PositionId" class="btn btn-danger" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                        }
                    </div>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center" role="alert">
        <i class="bi bi-info-circle"></i> No positions found. 
        @if (Context.Session.GetString("UserRoles")?.Contains("System Administrator") == true)
        {
            <a asp-action="Create" class="alert-link">Create the first position</a>
        }
    </div>
}
