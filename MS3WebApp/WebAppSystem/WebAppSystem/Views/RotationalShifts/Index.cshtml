@model IEnumerable<WebAppSystem.Models.ShiftCycle>

@{
    ViewData["Title"] = "Rotational Shifts";
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1><i class="bi bi-arrow-repeat"></i> Rotational Shift Cycles</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Create New Rotational Shift
        </a>
    </div>
    <hr />
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-hover table-striped">
        <thead>
            <tr>
                <th>Cycle ID</th>
                <th>Cycle Name</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
@foreach (var item in Model) {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.CycleId)</td>
                <td>@Html.DisplayFor(modelItem => item.CycleName)</td>
                <td>@Html.DisplayFor(modelItem => item.Description)</td>
                <td>
                    <div class="btn-group btn-group-sm" role="group">
                        <a asp-action="Details" asp-route-id="@item.CycleId" class="btn btn-info" title="Details">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.CycleId" class="btn btn-warning" title="Edit">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.CycleId" class="btn btn-danger" title="Delete">
                            <i class="bi bi-trash"></i>
                        </a>
                    </div>
                </td>
            </tr>
}
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center" role="alert">
        <i class="bi bi-info-circle"></i> No rotational shifts configured. <a asp-action="Create" class="alert-link">Create the first rotational shift</a>
    </div>
}
