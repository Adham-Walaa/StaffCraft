@model WebAppSystem.Models.SalaryType

@{
    ViewData["Title"] = "Details";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h2 class="mb-0"><i class="bi bi-currency-dollar"></i> Salary Type Details</h2>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">Salary Type ID</dt>
                    <dd class="col-sm-9">@Model.SalaryTypeId</dd>
                    
                    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Type)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.Type)</dd>
                    
                    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.PaymentFrequency)</dt>
                    <dd class="col-sm-9">@Html.DisplayFor(model => model.PaymentFrequency)</dd>
                    
                    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Currency)</dt>
                    <dd class="col-sm-9">
                        @if (!string.IsNullOrEmpty(Model.Currency))
                        {
                            <span class="badge bg-primary">@Model.Currency</span>
                        }
                        else
                        {
                            <span class="text-muted">N/A</span>
                        }
                    </dd>
                </dl>
                
                <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                    @if (Context.Session.GetString("UserRoles")?.Contains("System Administrator") == true)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.SalaryTypeId" class="btn btn-warning">
                            <i class="bi bi-pencil"></i> Edit
                        </a>
                    }
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
