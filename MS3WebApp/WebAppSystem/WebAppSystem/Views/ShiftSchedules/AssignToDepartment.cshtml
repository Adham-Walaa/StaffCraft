@model WebAppSystem.Models.ShiftAssignmentViewModel

@{
    ViewData["Title"] = "Assign Shift to Department";
    var shiftTemplates = ViewData["ShiftTemplates"] as IEnumerable<dynamic>;
}

<h1>Assign Shift to Department</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="AssignToDepartment">
            <div asp-validation-summary="All" class="text-danger"></div>
            
            <div class="alert alert-info">
                <strong>Note:</strong> This will assign the selected shift to all employees in the chosen department.
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="DepartmentId" class="control-label">Department</label>
                <select asp-for="DepartmentId" class="form-control" asp-items="ViewBag.DepartmentId">
                    <option value="">-- Select Department --</option>
                </select>
                <span asp-validation-for="DepartmentId" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="ShiftId" class="control-label">Shift Template</label>
                <select asp-for="ShiftId" class="form-control">
                    <option value="0">-- Select Shift Template --</option>
                    @if (shiftTemplates != null)
                    {
                        foreach (var template in shiftTemplates)
                        {
                            <option value="@template.ShiftId">@template.Display</option>
                        }
                    }
                </select>
                <span asp-validation-for="ShiftId" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="StartDate" class="control-label">Start Date</label>
                <input asp-for="StartDate" class="form-control" type="date" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>
            
            <div class="form-group mb-3">
                <label asp-for="EndDate" class="control-label">End Date</label>
                <input asp-for="EndDate" class="form-control" type="date" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <input type="submit" value="Assign to Department" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
