@model IEnumerable<WebAppSystem.Models.ShiftSchedule>

@{
    ViewData["Title"] = "Shift Schedules";
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <h1><i class="bi bi-calendar3"></i> Shift Schedules</h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Create New
        </a>
    </div>
    <hr />
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-hover table-striped">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.StartDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EndDate)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ShiftName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ShiftType)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StartTime)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EndTime)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Employee)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.StartDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EndDate)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ShiftName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ShiftType)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.StartTime)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.EndTime)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Employee.EmployeeId)
            </td>
            <td>
                <div class="btn-group btn-group-sm" role="group">
                    <a asp-action="Details" asp-route-id="@item.ShiftId" class="btn btn-info" title="Details">
                        <i class="bi bi-eye"></i>
                    </a>
                    @if (Context.Session.GetString("UserRoles")?.Contains("System Administrator") == true || 
                         Context.Session.GetString("UserRoles")?.Contains("Line Manager") == true)
                    {
                        <a asp-action="Edit" asp-route-id="@item.ShiftId" class="btn btn-warning" title="Edit">
                            <i class="bi bi-pencil"></i>
                        </a>
                    }
                    @if (Context.Session.GetString("UserRoles")?.Contains("System Administrator") == true)
                    {
                        <a asp-action="Delete" asp-route-id="@item.ShiftId" class="btn btn-danger" title="Delete">
                            <i class="bi bi-trash"></i>
                        </a>
                    }
                </div>
            </td>
        </tr>
}
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info text-center" role="alert">
        <i class="bi bi-info-circle"></i> No shift schedules found. <a asp-action="Create" class="alert-link">Create a new schedule</a>
    </div>
}
